{
  "name": "couple-meal-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:models:coverage": "vitest run --coverage",
    "doctor": "expo-doctor",
    "validate:release": "npm run doctor && npm run typecheck && npm run test:models:coverage && node scripts/validate-release.mjs"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.102.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1314.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@expo/env": "2.0.11",
    "@types/react": "~19.1.0",
    "@vitest/coverage-v8": "^4.1.4",
    "expo-doctor": "1.18.18",
    "typescript": "~5.9.2",
    "vitest": "^4.1.4"
  },
  "private": true
}
